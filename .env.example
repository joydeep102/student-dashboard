# Copy to ".env" and adjust. docker compose reads this automatically.

# --- Django ---
DJANGO_SECRET_KEY=please-generate-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com
DJANGO_TIME_ZONE=Asia/Kolkata

# --- Database (PostgreSQL) ---
POSTGRES_DB=fighterbulls
POSTGRES_USER=fbuser
POSTGRES_PASSWORD=change-me-db-pass

# Load demo data on first boot (set to 1 once, then back to 0)
SEED_DEMO=1
