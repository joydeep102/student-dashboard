# Copy to ".env" and adjust. docker compose reads this automatically.

# --- Django ---
DJANGO_SECRET_KEY=please-generate-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com
DJANGO_TIME_ZONE=Asia/Kolkata

# --- Database (PostgreSQL) ---
POSTGRES_DB=fighterbulls
POSTGRES_USER=fbuser
POSTGRES_PASSWORD=change-me-db-pass

# Load demo data on first boot (set to 1 once, then back to 0)
SEED_DEMO=1

# --- Payments: manual UPI (recorded-course checkout) ---
# Your UPI ID (VPA). Shown as a QR + intent link on the checkout page. Students
# pay here and submit the reference; an admin verifies it in the admin. Leave
# blank to hide the manual-UPI option.
UPI_VPA=yourname@okhdfcbank
UPI_PAYEE_NAME=Fighter Bulls
# On submitting a manual-UPI payment, the student previews this many lessons
# immediately; full access follows admin verification.
PROVISIONAL_PREVIEW_LESSONS=2

# --- Payments: Razorpay online checkout ---
# From the Razorpay dashboard. Online checkout is only offered when BOTH the key
# id and secret are set, so the site works fine before your keys arrive.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Set after adding the webhook in Razorpay (Settings → Webhooks). Point the
# webhook at https://your-domain.com/payments/razorpay/webhook/ and subscribe to
# the "payment.captured" and "order.paid" events.
RAZORPAY_WEBHOOK_SECRET=
